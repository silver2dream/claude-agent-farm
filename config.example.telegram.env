# Claude Agent Farm Configuration — Telegram
# Copy this file to config.telegram.env and fill in your values.
# DO NOT commit config.telegram.env to Git.

# ──────────────────────────────────────────────
# Telegram Bot (create via @BotFather on Telegram)
# NOTE: Telegram allows only ONE consumer per bot token.
#       Each agent needs its own bot. For additional agents,
#       use: make -f Makefile.telegram add-bot NAME=x BOT_TOKEN=y USER_ID=z
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_USER_ID=your-telegram-user-id-here

# ──────────────────────────────────────────────
# First Agent
# ──────────────────────────────────────────────
AGENT_NAME=my-first-agent
CHAT_ID=your-chat-id-here

# ──────────────────────────────────────────────
# Claude Credentials
# Path to your local ~/.claude directory
# The setup script copies credentials into K8s Secrets
# ──────────────────────────────────────────────
CLAUDE_CONFIG_DIR=~/.claude

# ──────────────────────────────────────────────
# Optional: Container image name
# ──────────────────────────────────────────────
IMAGE_NAME=claude-agent-telegram
IMAGE_TAG=latest
