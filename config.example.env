# Claude Agent Farm Configuration
# Copy this file to config.env and fill in your values.
# DO NOT commit config.env to Git.

# ──────────────────────────────────────────────
# Discord Bot (create at discord.com/developers)
# ──────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_GUILD_ID=your-guild-id-here
DISCORD_USER_ID=your-user-id-here

# ──────────────────────────────────────────────
# First Agent
# ──────────────────────────────────────────────
AGENT_NAME=my-first-agent
CHANNEL_ID=your-channel-id-here

# ──────────────────────────────────────────────
# Claude Credentials
# Path to your local ~/.claude directory
# The setup script copies credentials into K8s Secrets
# ──────────────────────────────────────────────
CLAUDE_CONFIG_DIR=~/.claude

# ──────────────────────────────────────────────
# Optional: Container image name
# ──────────────────────────────────────────────
IMAGE_NAME=claude-agent
IMAGE_TAG=latest
